# IBKR Gateway connection
IBKR_HOST=127.0.0.1
IBKR_PORT=4001
IBKR_CLIENT_ID_BASE=11

# Market data type: 1=realtime, 2=frozen, 3=delayed, 4=delayed-frozen
# Use 1 if you have realtime data subscriptions, 3 otherwise (free)
IBKR_MARKET_DATA_TYPE=1

# Optional: Finnhub API key for earnings calendar fallback
# Get free key at https://finnhub.io/
# FINNHUB_API_KEY=

# Optional: IBKR Flex Web Service for historical P&L analysis
# Configure at Account Management → Settings → Account Settings → Flex Web Service
# IBKR_FLEX_TOKEN=
# IBKR_FLEX_QUERY_ID=
